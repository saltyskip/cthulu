# Server
PORT=8081
ENVIRONMENT=local

# GitHub — needed for PR review trigger and merged PRs source
GITHUB_TOKEN=

# Slack — use webhook OR bot token (not both)
SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=

# Notion — needed for Notion sinks
NOTION_TOKEN=

# Cloud VM Pool — persistent pool of Firecracker VMs running ADK A2A agent servers
# Set VM_MANAGER_URL to enable cloud execution. Omit to run workflows locally only.
VM_MANAGER_URL=http://34.100.130.60:8080
VM_POOL_SIZE=5
VM_POOL_TIER=nano
ANTHROPIC_API_KEY=

# Firecracker sandbox (optional — omit to use DangerousHost default)
# Remote server with real /dev/kvm
FIRECRACKER_SSH_HOST=
FIRECRACKER_SSH_PORT=22
FIRECRACKER_SSH_KEY=
FIRECRACKER_API_URL=
FC_REMOTE_BIN=/usr/local/bin/firecracker
FC_REMOTE_STATE_DIR=/var/lib/firecracker
# Lima TCP (macOS dev path)
LIMA_INSTANCE=default
FC_KERNEL_IMAGE=
FC_ROOTFS_IMAGE=
FC_VCPU=1
FC_MEMORY_MB=256

# Google Sheets source (path to service account JSON key file)
GOOGLE_SERVICE_ACCOUNT_KEY=

# Agent SDK — use Claude Agent SDK instead of raw CLI subprocess for chat
# Requires `claude` CLI installed. Set ANTHROPIC_AUTH_TOKEN for OAuth auth
# (or run `claude auth login` to use Keychain instead).
AGENT_SDK_ENABLED=
ANTHROPIC_AUTH_TOKEN=

# Optional
SENTRY_DSN=
RUST_LOG=cthulu=info
