{
  "identifier": "default",
  "description": "Default capabilities for Cthulu Studio",
  "windows": ["main"],
  "permissions": [
    "dialog:default",
    "dialog:allow-open",
    "opener:default",
    "http:default",
    {
      "identifier": "http:allow-fetch",
      "allow": [
        { "url": "http://localhost:8081/**" },
        { "url": "ws://localhost:8081/**" }
      ]
    }
  ]
}
