{
  "name": "cthulu-mcp",
  "root": "cthulu-mcp",
  "projectType": "application",
  "tags": ["scope:mcp", "lang:rust"],
  "targets": {
    "build": {
      "command": "cargo build --release --bin cthulu-mcp",
      "inputs": ["rust"],
      "outputs": ["{workspaceRoot}/target/release/cthulu-mcp"],
      "cache": true,
      "metadata": {
        "description": "Build the cthulu MCP server (release mode)",
        "technologies": ["rust"]
      }
    },
    "dev": {
      "command": "cargo run --bin cthulu-mcp",
      "continuous": true,
      "metadata": {
        "description": "Run the cthulu MCP server in development mode",
        "technologies": ["rust"]
      }
    },
    "lint": {
      "command": "cargo clippy --bin cthulu-mcp -- -D warnings",
      "inputs": ["rust"],
      "cache": true,
      "metadata": {
        "description": "Lint cthulu-mcp with clippy",
        "technologies": ["rust"]
      }
    }
  }
}
